2️⃣ Identity Class
public class Identity {

    private String name;
    private boolean hasCreateRole;
    private boolean hasApproveRole;

    public Identity(String name, boolean hasCreateRole, boolean hasApproveRole) {
        this.name = name;
        this.hasCreateRole = hasCreateRole;
        this.hasApproveRole = hasApproveRole;
    }

    public String getName() {
        return name;
    }

    public boolean hasCreateRole() {
        return hasCreateRole;
    }

    public boolean hasApproveRole() {
        return hasApproveRole;
    }

    // Automatic remediation: revoke Approve role
    public void revokeApproveRole() {
        if(hasApproveRole) {
            hasApproveRole = false;
            System.out.println("Automatic Remediation: Approve Role revoked for " + name);
        }
    }
}
3️⃣ Violation Class
public class Violation {

    private Identity user;
    private String policyName;
    private String reason;

    public Violation(Identity user, String policyName, String reason) {
        this.user = user;
        this.policyName = policyName;
        this.reason = reason;
    }

    public void printViolation() {
        System.out.println("VIOLATION DETECTED");
        System.out.println("User: " + user.getName());
        System.out.println("Policy: " + policyName);
        System.out.println("Reason: " + reason);
        System.out.println("----------------------");
    }

    public void remediate() {
        System.out.println("REMEDIATION STARTED for " + user.getName());
        user.revokeApproveRole();
        System.out.println("----------------------");
    }
}
4️⃣ Policy Engine (Detect + Remediate)
import java.util.ArrayList;
import java.util.List;

public class PolicyEngine {

    private List<Violation> violations = new ArrayList<>();

    public void evaluateSoD(Identity user) {
        if(user.hasCreateRole() && user.hasApproveRole()) {
            Violation v = new Violation(user, "SoD Policy", "User has conflicting roles: Create & Approve");
            violations.add(v);
        }
    }

    public void processViolations() {
        if(violations.isEmpty()) {
            System.out.println("No violations detected");
        } else {
            for(Violation v : violations) {
                v.printViolation();
                v.remediate();
            }
        }
    }
}
5️⃣ Main Program (Enterprise Simulation)
public class Main {

    public static void main(String[] args) {

        // Users
        Identity rahul = new Identity("Rahul", true, true); // Has conflicting roles
        Identity amit = new Identity("Amit", true, false);  // No conflict

        // Policy Engine
        PolicyEngine engine = new PolicyEngine();

        // Evaluate SoD Policy
        engine.evaluateSoD(rahul);
        engine.evaluateSoD(amit);

        // Process Violations
        engine.processViolations();

        // Check final state
        System.out.println("Final Role State:");
        System.out.println("Rahul - Approve Role: " + rahul.hasApproveRole());
        System.out.println("Amit - Approve Role: " + amit.hasApproveRole());
    }
}


6️⃣ Output (Workable Enterprise Simulation):-
