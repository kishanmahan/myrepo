import java.util.ArrayList;
import java.util.List;

class TechnicalRole {

    String roleName;
    String application;
    List<String> permissions = new ArrayList<String>();

    TechnicalRole(String roleName) {
        this.roleName = roleName;
    }

    void addPermission(String permission) {
        permissions.add(permission);
    }

    void setApplication(String application) {
        this.application = application;
    }
}

class BusinessRole {

    String roleName;
    List<TechnicalRole> technicalRoles = new ArrayList<TechnicalRole>();

    BusinessRole(String roleName) {
        this.roleName = roleName;
    }

    void addTechnicalRole(TechnicalRole role) {
        technicalRoles.add(role);
    }
}

class Identity {

    String empId;
    List<BusinessRole> businessRoles = new ArrayList<BusinessRole>();

    Identity(String empId) {
        this.empId = empId;
    }

    void assignBusinessRole(BusinessRole role) {

        businessRoles.add(role);

        System.out.println("Business Role Assigned: " + role.roleName);

        // Apply permissions automatically
        for (TechnicalRole tRole : role.technicalRoles) {

            System.out.println("Application: " + tRole.application);

            for (String perm : tRole.permissions) {
                System.out.println("Permission Granted: " + perm);
            }
        }

        enforcePolicies(role);
    }

    void enforcePolicies(BusinessRole role) {

        System.out.println("Checking Security Policies...");

        // Example SoD Policy
        boolean hasRead = false;
        boolean hasWrite = false;

        for (TechnicalRole tRole : role.technicalRoles) {
            for (String perm : tRole.permissions) {

                if (perm.equals("Read Finance Reports")) {
                    hasRead = true;
                }

                if (perm.equals("Write Finance Reports")) {
                    hasWrite = true;
                }
            }
        }

        if (hasRead && hasWrite) {
            System.out.println("SoD Warning: User has both Read and Write Finance access.");
        }

        // MFA Simulation
        System.out.println("MFA Required for Finance System Access.");
    }
}

public class IAMExample {

    static Identity getIdentity(String empId) {
        return new Identity(empId);
    }

    public static void main(String[] args) {

        Identity rahul = getIdentity("EMP12345");

        // Define Technical Role
        TechnicalRole sapAdmin = new TechnicalRole("SAP Admin");
        sapAdmin.addPermission("Read Finance Reports");
        sapAdmin.addPermission("Write Finance Reports");
        sapAdmin.setApplication("SAP");

        // Define Business Role
        BusinessRole financeManager = new BusinessRole("Finance Manager");
        financeManager.addTechnicalRole(sapAdmin);

        // Assign Business Role
        rahul.assignBusinessRole(financeManager);
    }
}
