import java.util.ArrayList;
import java.util.List;

class TechnicalRole {

    String roleName;
    String application;
    List<String> permissions = new ArrayList<String>();

    TechnicalRole(String roleName) {
        this.roleName = roleName;
    }

    void setApplication(String app) {
        this.application = app;
    }

    void addPermission(String perm) {
        permissions.add(perm);
    }
}

class BusinessRole {

    String roleName;
    List<TechnicalRole> technicalRoles = new ArrayList<TechnicalRole>();

    BusinessRole(String roleName) {
        this.roleName = roleName;
    }

    void addTechnicalRole(TechnicalRole role) {
        technicalRoles.add(role);
    }
}

class Identity {

    String name;
    List<BusinessRole> roles = new ArrayList<BusinessRole>();

    Identity(String name) {
        this.name = name;
    }

    void assignBusinessRole(BusinessRole role) {

        roles.add(role);

        System.out.println("\nUser: " + name);
        System.out.println("Business Role: " + role.roleName);

        for (TechnicalRole tRole : role.technicalRoles) {

            System.out.println(" Application: " + tRole.application);
            System.out.println(" Technical Role: " + tRole.roleName);

            for (String perm : tRole.permissions) {
                System.out.println("  Permission: " + perm);
            }
        }
    }
}

public class IAMSystem {

    public static void main(String[] args) {

        // Technical Role 1
        TechnicalRole sapAdmin = new TechnicalRole("SAP Admin");
        sapAdmin.setApplication("SAP");
        sapAdmin.addPermission("Read Finance Reports");
        sapAdmin.addPermission("Write Finance Reports");

        // Technical Role 2
        TechnicalRole oracleDBA = new TechnicalRole("Oracle DBA");
        oracleDBA.setApplication("Oracle DB");
        oracleDBA.addPermission("Read Database");
        oracleDBA.addPermission("Modify Database");

        // Business Role
        BusinessRole financeManager = new BusinessRole("Finance Manager");

        financeManager.addTechnicalRole(sapAdmin);
        financeManager.addTechnicalRole(oracleDBA);

        // Multiple Users
        Identity rahul = new Identity("Rahul");
        Identity ram = new Identity("Ram");
        Identity raman = new Identity("Raman");

        List<Identity> users = new ArrayList<Identity>();

        users.add(rahul);
        users.add(ram);
        users.add(raman);

        // Assign role to all users
        for (Identity user : users) {
            user.assignBusinessRole(financeManager);
        }
    }
}

