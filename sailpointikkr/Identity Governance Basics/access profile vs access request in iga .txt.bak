2️⃣ Access Profile Create Code
import java.io.OutputStream;
import java.net.HttpURLConnection;
import java.net.URL;

public class AccessProfileCreate {

    public static void main(String[] args) throws Exception {

        String apiUrl = "https://tenant.api.identitynow.com/v3/access-profiles";

        URL url = new URL(apiUrl);
        HttpURLConnection conn = (HttpURLConnection) url.openConnection();

        conn.setRequestMethod("POST");
        conn.setRequestProperty("Authorization", "Bearer YOUR_ACCESS_TOKEN");
        conn.setRequestProperty("Content-Type", "application/json");
        conn.setDoOutput(true);

        String jsonInput = "{"
                + "\"name\": \"Salesforce Read Access\","
                + "\"description\": \"Access to Salesforce read data\","
                + "\"sourceId\": \"2c9180847e9b1a1f017e9c1234567890\""
                + "}";

        OutputStream os = conn.getOutputStream();
        os.write(jsonInput.getBytes());
        os.flush();

        System.out.println("Response Code: " + conn.getResponseCode());
    }
}
3️⃣ Access Profile List Code
import java.net.HttpURLConnection;
import java.net.URL;
import java.io.BufferedReader;
import java.io.InputStreamReader;

public class AccessProfileList {

    public static void main(String[] args) throws Exception {

        URL url = new URL("https://tenant.api.identitynow.com/v3/access-profiles");

        HttpURLConnection conn = (HttpURLConnection) url.openConnection();

        conn.setRequestMethod("GET");
        conn.setRequestProperty("Authorization", "Bearer YOUR_ACCESS_TOKEN");

        BufferedReader br = new BufferedReader(
                new InputStreamReader(conn.getInputStream()));

        String line;

        while ((line = br.readLine()) != null) {
            System.out.println(line);
        }
    }
}
4️⃣ Access Request Code

User access profile request karega.

import java.io.OutputStream;
import java.net.HttpURLConnection;
import java.net.URL;

public class AccessRequest {

    public static void main(String[] args) throws Exception {

        URL url = new URL("https://tenant.api.identitynow.com/v3/access-requests");

        HttpURLConnection conn = (HttpURLConnection) url.openConnection();

        conn.setRequestMethod("POST");
        conn.setRequestProperty("Authorization", "Bearer YOUR_ACCESS_TOKEN");
        conn.setRequestProperty("Content-Type", "application/json");

        conn.setDoOutput(true);

        String requestBody = "{"
                + "\"requestedFor\": \"2c9180847e9b1a1f017e9c1111111111\","
                + "\"accessProfileIds\": [\"2c9180847e9b1a1f017e9c2222222222\"]"
                + "}";

        OutputStream os = conn.getOutputStream();
        os.write(requestBody.getBytes());
        os.flush();

        System.out.println("Access Request Response: " + conn.getResponseCode());
    }
}
output:-
✅ Success Output
Response Code: 201

Meaning:

Access Profile successfully create ho gaya

API response (example JSON):

{
 "id": "2c9180847e9b1a1f017e9c9999999999",
 "name": "Salesforce Read Access",
 "description": "Access to Salesforce read data",
 "sourceId": "2c9180847e9b1a1f017e9c1234567890"
}

