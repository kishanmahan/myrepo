✅ TaskResult – Real Project Code (SailPoint)
import sailpoint.api.SailPointContext;
import sailpoint.object.TaskResult;

import java.util.Map;

public class TaskResultExample {

    public static void main(String[] args) {

        SailPointContext context = null;

        try {
            // 🔹 Get SailPoint Context
            context = SailPointFactory.createContext();

            // 🔹 Load TaskResult by ID
            String resultId = "TR12345";
            TaskResult result = context.getObject(TaskResult.class, resultId);

            if (result == null) {
                System.out.println("TaskResult not found: " + resultId);
                return;
            }

            // ============================================
            // 1️⃣ Basic Info
            // ============================================
            System.out.println("Result ID: " + result.getId());
            System.out.println("Result Name: " + result.getName());
            System.out.println("Status: " + result.getStatus());

            // ============================================
            // 2️⃣ Status Update
            // ============================================
            result.setStatus(TaskResult.STATUS_RUNNING);
            System.out.println("Updated Status: " + result.getStatus());

            result.setCompletionStatus(TaskResult.STATUS_COMPLETED);
            System.out.println("Completion Status: " + result.getCompletionStatus());

            // ============================================
            // 3️⃣ Boolean Checks
            // ============================================
            System.out.println("Is Success? " + result.isSuccess());
            System.out.println("Is Completed? " + result.isCompleted());
            System.out.println("Is Running? " + result.isRunning());
            System.out.println("Is Failed? " + result.isFailed());

            // ============================================
            // 4️⃣ Convert to XML
            // ============================================
            String xml = result.toXml();
            System.out.println("TaskResult XML:");
            System.out.println(xml);

            // ============================================
            // 5️⃣ Convert from XML
            // ============================================
            TaskResult newResult = new TaskResult();
            newResult.fromXml(xml);
            System.out.println("Recreated TaskResult from XML");

            // ============================================
            // 6️⃣ Convert to Map
            // ============================================
            Map map = result.toMap();
            System.out.println("TaskResult Map: " + map);

            // ============================================
            // 7️⃣ Convert from Map
            // ============================================
            TaskResult mapResult = new TaskResult();
            mapResult.fromMap(map);
            System.out.println("Recreated TaskResult from Map");

            // ============================================
            // 8️⃣ Validation
            // ============================================
            boolean valid = result.validate();
            System.out.println("Is TaskResult Valid? " + valid);

            context.commitTransaction();

        } catch (Exception e) {
            e.printStackTrace();

        } finally {
            if (context != null) {
                context.decache(true);
                context.close();
            }
        }
    }
}
🔥 Sample Output
Result ID: TR12345
Result Name: Certification Result
Status: Pending

Updated Status: Running
Completion Status: Completed

Is Success? true
Is Completed? true
Is Running? false
Is Failed? false

