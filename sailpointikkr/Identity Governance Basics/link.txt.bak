import sailpoint.object.Link;

public class LinkCommonMethods {

    public static void main(String[] args) {

        Link link1 = new Link();
        link1.setDisplayName("Kishan Account");

        // =========================
        // 🔹 clone
        // =========================
        Link link2 = (Link) link1.clone();

        // =========================
        // 🔹 equals
        // =========================
        System.out.println("Equals: " + link1.equals(link2));

        // =========================
        // 🔹 hashCode
        // =========================
        System.out.println("HashCode link1: " + link1.hashCode());
        System.out.println("HashCode link2: " + link2.hashCode());

        // =========================
        // 🔹 toString
        // =========================
        System.out.println("ToString: " + link1.toString());

        // =========================
        // 🔹 validate
        // =========================
        try {
            link1.validate();
            System.out.println("Validation: Success");
        } catch (Exception e) {
            System.out.println("Validation: Failed");
        }
    }
}
✅ Output (Example)
Equals: true
HashCode link1: 12345678
HashCode link2: 12345678
ToString: Link[Kishan Account]
Validation: Success

🔹 validate():-
👉 Object valid hai ya nahi check karta hai
📌 Check karta hai:-
Required fields set hain ya nahi
Data sahi format me hai ya nahi
👉 Error hua to exception throw karega.
--------------------------------------------------------------------------------------------------------------------------------
✅ Link me validate() kya kya check karta hai?
validate() basically check karta hai ki Link object sahi bana hai ya nahi (usable hai ya nahi).

🔹 1. Application check:-
👉 Link me Application set hai ya nahi
link.getApplication() != null
❌ Nahi hua → invalid

🔹 2. Identity check;-
👉 Link kisi Identity (user) se linked hai ya nahi
link.getIdentity() != null
❌ Nahi hua → invalid

🔹 3. Native Identity check:-
👉 External system ka account id (username) hai ya nahi
link.getNativeIdentity() != null
❌ Nahi hua → invalid

🔹 4. Required fields consistency:-
👉 Important fields empty ya inconsistent na ho
displayName empty ho sakta hai (optional)
but core fields missing nahi hone chahiye

🔹 5. Attribute structure check:-
👉 Attributes map valid hai ya nahi
link.getAttributes() instanceof Map

🔹 6. Entitlements validity:-
👉 Entitlements list valid format me hai ya nahi
null ho sakta hai
but wrong type nahi hona chahiye

🔹 7. Permissions validity:-
👉 Permissions bhi correct structure me ho

🔹 8. Internal object integrity:-
👉 Object corrupted nahi hai
duplicate values
invalid references

✅ Code (Validate Pass + Fail Cases)
import sailpoint.object.Link;
import sailpoint.object.Identity;
import sailpoint.object.Application;
import java.util.Map;
import java.util.HashMap;
import java.util.List;
import java.util.ArrayList;

public class LinkValidateDemo {

    public static void main(String[] args) {

        // =========================
        // ❌ FAIL CASE
        // =========================
        try {
            Link linkFail = new Link();

            // intentionally kuch set nahi kiya
            linkFail.validate();

            System.out.println("Fail Case: Passed (unexpected)");
        } catch (Exception e) {
            System.out.println("Fail Case: Validation Failed");
        }


        // =========================
        // ✅ PASS CASE
        // =========================
        try {
            Link link = new Link();

            // 🔹 Identity
            Identity identity = new Identity();
            identity.setName("Kishan");
            link.setIdentity(identity);

            // 🔹 Application
            Application app = new Application();
            app.setName("ActiveDirectory");
            link.setApplication(app);

            // 🔹 Native Identity
            link.setNativeIdentity("kishan.ad");

            // 🔹 Attributes (valid Map)
            Map<String, Object> attrs = new HashMap<String, Object>();
            attrs.put("email", "kishan@example.com");
            link.setAttributes(attrs);

            // 🔹 Entitlements (valid List)
            List<String> ents = new ArrayList<String>();
            ents.add("ROLE_USER");
            link.setEntitlements(ents);

            // 🔹 Permissions (valid List)
            List<String> perms = new ArrayList<String>();
            perms.add("READ");
            link.setPermissions(perms);

            // 🔹 Validate
            link.validate();

            System.out.println("Pass Case: Validation Success");

        } catch (Exception e) {
            System.out.println("Pass Case: Validation Failed");
        }
    }
}
✅ Output:-
Fail Case: Validation Failed
Pass Case: Validation Success