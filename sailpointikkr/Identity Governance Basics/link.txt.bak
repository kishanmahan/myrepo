✅ Code Example
import sailpoint.object.Link;
import java.util.Date;

public class LinkAuditExample {

    public static void main(String[] args) {

        Link link = new Link();

        // =========================
        // 🔹 DATE / AUDIT
        // =========================

        Date now = new Date();

        link.setLastRefresh(now);
        link.setLastLogin(now);

        System.out.println("Created: " + link.getCreated());
        System.out.println("Modified: " + link.getModified());
        System.out.println("Created By: " + link.getCreatedBy());
        System.out.println("Modified By: " + link.getModifiedBy());
        System.out.println("Last Refresh: " + link.getLastRefresh());
        System.out.println("Last Login: " + link.getLastLogin());

        // =========================
        // 🔹 STATUS / TYPE / DESC
        // =========================

        link.setStatus("ACTIVE");
        link.setType("ACCOUNT");
        link.setDescription("Kishan AD Account");

        System.out.println("Status: " + link.getStatus());
        System.out.println("Type: " + link.getType());
        System.out.println("Description: " + link.getDescription());
    }
}
✅ Output:-
Created: null
Modified: null
Created By: null
Modified By: null
Last Refresh: Wed Mar 18 12:30:00 IST 2026
Last Login: Wed Mar 18 12:30:00 IST 2026

Status: ACTIVE
Type: ACCOUNT
Description: Kishan AD Account
