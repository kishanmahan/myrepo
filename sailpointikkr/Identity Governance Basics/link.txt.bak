✅ Code (Without * import)
import sailpoint.object.Link;
import java.util.Map;
import java.util.HashMap;
import java.util.List;
import java.util.ArrayList;

public class LinkFullExample {

    public static void main(String[] args) {

        Link link = new Link();

        // =========================
        // 🔹 ATTRIBUTES
        // =========================

        // setAttributes → pura map set karta hai
        Map<String, Object> attrs = new HashMap<String, Object>();
        attrs.put("email", "kishan@example.com");
        link.setAttributes(attrs);

        // getAttributes → saare attributes deta hai
        System.out.println("All Attributes: " + link.getAttributes());

        // setAttribute → ek single attribute add/update karta hai
        link.setAttribute("department", "IT");

        // getAttribute → ek specific value deta hai
        System.out.println("Department: " + link.getAttribute("department"));

        // removeAttribute → attribute hata deta hai
        link.removeAttribute("email");
        System.out.println("After Remove Email: " + link.getAttributes());


        // =========================
        // 🔹 ENTITLEMENTS
        // =========================

        // setEntitlements → pura list set karta hai
        List<String> ents = new ArrayList<String>();
        ents.add("ROLE_USER");
        link.setEntitlements(ents);

        // addEntitlement → ek aur entitlement add karta hai
        link.addEntitlement("ROLE_ADMIN");

        // getEntitlements → saare roles deta hai
        System.out.println("Entitlements: " + link.getEntitlements());

        // removeEntitlement → role hata deta hai
        link.removeEntitlement("ROLE_USER");
        System.out.println("After Remove Entitlement: " + link.getEntitlements());


        // =========================
        // 🔹 PERMISSIONS
        // =========================

        // setPermissions → pura permission list set karta hai
        List<String> perms = new ArrayList<String>();
        perms.add("READ");
        link.setPermissions(perms);

        // addPermission → ek permission add karta hai
        link.addPermission("WRITE");

        // getPermissions → saare permissions deta hai
        System.out.println("Permissions: " + link.getPermissions());

        // removePermission → permission hata deta hai
        link.removePermission("READ");
        System.out.println("After Remove Permission: " + link.getPermissions());

        // getPermission → (single permission access pattern, generally list se)
        System.out.println("Single Permission (example): " + link.getPermissions().get(0));

        // setPermission → (single permission set karne ka pattern, list replace karke)
        List<String> singlePerm = new ArrayList<String>();
        singlePerm.add("EXECUTE");
        link.setPermissions(singlePerm);

        System.out.println("After setPermission (replace): " + link.getPermissions());
    }
}
✅ Output
All Attributes: {email=kishan@example.com}
Department: IT
After Remove Email: {department=IT}

Entitlements: [ROLE_USER, ROLE_ADMIN]
After Remove Entitlement: [ROLE_ADMIN]

Permissions: [READ, WRITE]
After Remove Permission: [WRITE]
Single Permission (example): WRITE
After setPermission (replace): [EXECUTE]
---------------------------------------------------------------------------------------------------------------------------
()setAttributes(Map):-
👉 Pure account ke attributes ek baar me set karta hai
👉 Old values replace ho jaati hain

()getAttributes():-
👉 Account ke saare attributes ek map me return karta hai
👉 Jaise: email, department, location

()setAttribute(String key, Object value):-
👉 Ek single attribute add ya update karta hai
Example:-
location = India add kar diya

()getAttribute(String key):-
👉 Kisi ek attribute ki value deta hai
Example:-
email → kishan@example.com

()removeAttribute(String key):-
👉 Attribute delete kar deta hai
Example:-
department hata diya

()Ye high-level access hote hain:-
👉 Jaise: ROLE_USER, ROLE_ADMIN

()setEntitlements(List):-
👉 Saare roles ek baar me set karta hai
👉 Old roles replace ho jaate hain

()getEntitlements():-
👉 User ke saare roles return karta hai

()addEntitlement(String):-
👉 Ek naya role add karta hai
removeEntitlement(String)
👉 Role hata deta hai.

()Ye fine-grained access hota hai:-
👉 Jaise: READ, WRITE, EXECUTE

()setPermissions(List):-
👉 Saare permissions set karta hai

()getPermissions():-
👉 Saare permissions return karta hai

()addPermission(String):-
👉 Ek permission add karta hai

()removePermission(String):-
👉 Permission hata deta hai

()getPermission():-
👉 Direct method rarely use hota hai
👉 Generally list se access karte hain

()setPermission():-
👉 Practically use nahi hota.
------------------------------------------------------------------------------------------------------------------------------------
🔹 setDisabled(boolean):-
👉 Account ko disable / enable karta hai
true → account disable (login allowed nahi)
false → account active
📌 Example:-
Employee company chhod gaya → account disable
--------
🔹 isDisabled():-
👉 Check karta hai account disabled hai ya nahi
true → disabled
false → active
----------
🔹 setLocked(boolean):-
👉 Account ko lock / unlock karta hai
true → account locked
false → unlocked
📌 Example:-
3 baar wrong password → account lock
---------------
🔹 isLocked():-
👉 Check karta hai account locked hai ya nahi.

✅ Code Example
import sailpoint.object.Link;

public class LinkStatusExample {

    public static void main(String[] args) {

        Link link = new Link();

        // =========================
        // 🔹 DISABLED
        // =========================

        // setDisabled → account disable karna
        link.setDisabled(true);

        // isDisabled → check account disabled hai ya nahi
        System.out.println("Is Disabled: " + link.isDisabled());


        // =========================
        // 🔹 LOCKED
        // =========================

        // setLocked → account lock karna
        link.setLocked(true);

        // isLocked → check account locked hai ya nahi
        System.out.println("Is Locked: " + link.isLocked());
    }
}
✅ Output
Is Disabled: true
Is Locked: true
