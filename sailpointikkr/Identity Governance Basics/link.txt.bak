Code Example: Print Link in SailPoint Workflow
import sailpoint.workflow.WorkflowContext;
import java.util.HashMap;
import java.util.Map;

public class PrintLinkWorkflow {

    public void execute(WorkflowContext context) {

        // 1️⃣ System Property get karna (example: application URL)
        String appUrl = context.getProperty("sailpoint.application.url");
        if(appUrl == null) {
            appUrl = "https://sailpoint.example.com";
        }

        // 2️⃣ Workflow arguments set karna
        Map<String, Object> args = new HashMap<>();
        args.put("userName", "Kishan");
        context.setArguments(args);

        // 3️⃣ Launch message me link set karna
        String workflowLink = appUrl + "/workflow/123?user=" + args.get("userName");
        context.setLaunchMessage(workflowLink);

        // 4️⃣ Console me print karna
        System.out.println("Workflow Launch Link: " + context.getLaunchMessage());

        // 5️⃣ Message add karna (UI me dikhne ke liye)
        context.addMessage("Workflow successfully started for user: " + args.get("userName"));
    }
}
Expected Output (Console / Logs)
Workflow Launch Link: https://sailpoint.example.com/workflow/123?user=Kishan
UI / Workflow Message

Workflow UI me ye message dikh sakta hai:

Workflow successfully started for user: Kishan
-----------------------------------------------------------------------------------------------------------------------------
Example:-

import sailpoint.workflow.WorkflowContext;

public class PrintDefaultLink {
    public void execute(WorkflowContext context) {
        // Default launch message ko print karna
        System.out.println("Workflow Launch Link: " + context.getLaunchMessage());
    }
}
