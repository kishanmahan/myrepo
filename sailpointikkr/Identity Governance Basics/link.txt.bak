✅ Code Example
import sailpoint.object.Link;
import sailpoint.object.Identity;
import sailpoint.object.Application;

public class LinkExample {

    public static void main(String[] args) {

        // Link object create
        Link link = new Link();

        // Dummy objects (normally SailPoint se milte hain)
        Identity identity = new Identity();
        identity.setName("Kishan");

        Application app = new Application();
        app.setName("ActiveDirectory");

        // set methods
        link.setId("12345");
        link.setIdentity(identity);
        link.setApplication(app);
        link.setNativeIdentity("kishan.ad");
        link.setDisplayName("Kishan AD Account");

        // get methods + print
        System.out.println("ID: " + link.getId());
        System.out.println("Identity: " + link.getIdentity().getName());
        System.out.println("Application: " + link.getApplication().getName());
        System.out.println("Native Identity: " + link.getNativeIdentity());
        System.out.println("Display Name: " + link.getDisplayName());
    }
}
✅ Output
ID: 12345
Identity: Kishan
Application: ActiveDirectory
Native Identity: kishan.ad
Display Name: Kishan AD Account
