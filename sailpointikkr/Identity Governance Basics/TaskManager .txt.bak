}
5️⃣ TaskExecutor.java
package com.sailpoint.demo.executor;

import com.sailpoint.api.SailPointContext;
import com.sailpoint.demo.model.Task;
import com.sailpoint.demo.model.TaskResult;

public class TaskExecutor {

    private SailPointContext context;

    public TaskExecutor(SailPointContext context) {
        this.context = context;
    }

    public TaskResult run(Task task) {
        try {
            task.setRunning(true);
            TaskResult result = task.getDefinition().getHandler().execute(context);
            task.setResult(result);
            return result;
        } finally {
            task.setRunning(false);
        }
    }
}
6️⃣ IdentityRefreshHandler.java – No lambda, classic style
package com.sailpoint.demo.handlers;

import com.sailpoint.api.SailPointContext;
import com.sailpoint.demo.executor.TaskHandler;
import com.sailpoint.demo.model.TaskResult;

public class IdentityRefreshHandler implements TaskHandler {

    public IdentityRefreshHandler() { }

    @Override
    public TaskResult execute(SailPointContext context) {
        // Simulate work
        try {
            Thread.sleep(2000);
        } catch (InterruptedException e) { }
        return new TaskResult("SUCCESS", "Identity refreshed successfully");
    }
}
