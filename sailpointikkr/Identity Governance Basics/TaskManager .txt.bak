8️⃣ TaskManager.java – All methods
package com.sailpoint.demo.manager;

import com.sailpoint.api.SailPointContext;
import com.sailpoint.demo.model.Task;
import com.sailpoint.demo.model.TaskDefinition;
import com.sailpoint.demo.model.TaskResult;
import com.sailpoint.demo.executor.TaskExecutor;

import java.time.LocalDateTime;
import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

public class TaskManager {

    private Map<String, Task> tasks = new HashMap<String, Task>();
    private TaskExecutor executor;

    public TaskManager(SailPointContext context) {
        this.executor = new TaskExecutor(context);
    }

    // ----- Launch Methods -----
    public void run(TaskDefinition taskDef) {
        final Task task = new Task(taskDef);
        tasks.put(taskDef.getId(), task);
        new Thread() {
            public void run() {
                executor.run(task);
            }
        }.start();
    }

    public void runSync(TaskDefinition taskDef) {
        Task task = new Task(taskDef);
        tasks.put(taskDef.getId(), task);
        executor.run(task);
    }

    public TaskResult runWithResult(TaskDefinition taskDef) {
        Task task = new Task(taskDef);
        tasks.put(taskDef.getId(), task);
        return executor.run(task);
    }

    // ----- Schedule -----
    public void schedule(TaskDefinition taskDef, LocalDateTime runTime) {
        Task task = new Task(taskDef);
        task.setNextRunTime(runTime);
        tasks.put(taskDef.getId(), task);
    }

    public void reschedule(Task task, LocalDateTime newTime) {
        task.setNextRunTime(newTime);
    }

    public void deleteSchedule(Task task) {
        task.setNextRunTime(null);
    }

    // ----- Task Control -----
    public void cancel(Task task) {
        task.setRunning(false);
        System.out.println(task.getDefinition().getName() + " cancelled gracefully");
    }

    public void terminate(Task task) {
        task.setRunning(false);
        System.out.println(task.getDefinition().getName() + " terminated forcefully 💀");
    }

    // ----- Monitoring -----
    public TaskResult getTaskResult(Task task) { return task.getResult(); }
    public List<Task> getRunningTasks() {
        List<Task> running = new ArrayList<Task>();
        for (Task t : tasks.values()) {
            if (t.isRunning()) running.add(t);
        }
        return running;
    }
    public Task getTaskById(String id) { return tasks.get(id); }

    // ----- History -----
    public List<TaskResult> getTaskResults() {
        List<TaskResult> results = new ArrayList<TaskResult>();
        for(Task t : tasks.values()) if(t.getResult() != null) results.add(t.getResult());
        return results;
    }

    public TaskResult getLastResult(TaskDefinition taskDef) {
        Task t = tasks.get(taskDef.getId());
        return t != null ? t.getResult() : null;
    }

    // ----- Helpers -----
    public List<Task> getTasks() { return new ArrayList<Task>(tasks.values()); }
    public List<TaskDefinition> getTaskDefinitions() {
        List<TaskDefinition> defs = new ArrayList<TaskDefinition>();
        for(Task t : tasks.values()) defs.add(t.getDefinition());
        return defs;
    }
    public List<Task> getScheduledTasks() {
        List<Task> scheduled = new ArrayList<Task>();
        for(Task t : tasks.values()) if(t.getNextRunTime() != null) scheduled.add(t);
        return scheduled;
    }
    public boolean isTaskRunning(Task task) { return task.isRunning(); }
}
9️⃣ Main.java – Working demo with SailPointContextFactory
package com.sailpoint.demo;

import com.sailpoint.api.SailPointContext;
import com.sailpoint.api.SailPointContextFactory;
import com.sailpoint.demo.model.TaskDefinition;
import com.sailpoint.demo.model.Task;
import com.sailpoint.demo.manager.TaskManager;
import com.sailpoint.demo.handlers.IdentityRefreshHandler;
import com.sailpoint.demo.handlers.ReportGenerationHandler;

import java.time.LocalDateTime;
import java.util.List;

public class Main {

    public static void main(String[] args) throws Exception {

        // 🔹 SailPoint Context
        SailPointContext context = SailPointContextFactory.createContext();

        TaskManager taskManager = new TaskManager(context);

        // 🔹 Task Definitions
        TaskDefinition identityTask = new TaskDefinition("1", "Identity Refresh", "Daily Job", new IdentityRefreshHandler());
        TaskDefinition reportTask = new TaskDefinition("2", "Weekly Report", "Weekly Job", new ReportGenerationHandler());

        // 🔹 Run Async
        taskManager.run(identityTask);
        System.out.println("Identity task started...");

        // 🔹 Run Sync
        taskManager.runSync(reportTask);
        System.out.println("Report task completed synchronously");

        // 🔹 Schedule
        taskManager.schedule(identityTask, LocalDateTime.now().plusMinutes(5));
        System.out.println("Scheduled Identity task for later: " + identityTask.getName());

        // 🔹 Monitor
        List<Task> running = taskManager.getRunningTasks();
        System.out.println("Running tasks count: " + running.size());

        Task t = taskManager.getTaskById("1");
        Thread.sleep(3000); // Wait for async task to complete
        System.out.println("Identity Task Status: " + taskManager.getTaskResult(t).getStatus());
    }
}
🔹 Expected Output
Identity task started...
Report task completed synchronously
Scheduled Identity task for later: Identity Refresh
Running tasks count: 1
Identity Task Status: SUCCESS
///////////////*
()finally block:-try {return result;} finally { task.setRunning(false);:-
Java me finally block hamesha execute hota hai, chahe try me exception aaye ya return statement chale.
Iska matlab hai ki return result ke baad bhi task.setRunning(false) execute hoga.

()1️⃣ SailPointContextFactory.createContext():-
Ye SailPoint ka standard method hai jo SailPointContext banata hai.
SailPointContext = main object jo IAM system me kaam karta hai, jaise:
Identities read/write karna
Account provisioning
Rules aur tasks execute karna
Audit / logging access
Kya hota hai:
Ye internally connection establish karta hai system ke backend ke saath (database, config, etc.)
Tumhare handlers ko ye context pass kiya jata hai taaki wo system data access kar sake.

()3️⃣ final Task task:-
Jab hum Thread me task run karte hain,toh Java me inner class(Thread ke andar) me task variable ko final ya effectively final declare karna padta hai.
Kya hota hai:-
final ensures Thread ke andar variable change na ho
Thread safe banata hai
final Task task = new Task(taskDef);
Matlab ye task instance ab thread ke andar safely use ho sakta hai.

()4️⃣ new Thread() { public void run() { executor.run(task); } }.start();:-
Ye async execution ka standard Java way hai (lambdas nahi use kiye).
Kya hota hai:-
Nayi thread create hoti hai
Thread me executor.run(task) call hota hai → Task background me run hota hai
.start() se thread chalna start hota hai
Async ka matlab:-
Main program wait nahi karta
Turant aage execute hota hai

()6️⃣ task.getDefinition().getHandler().execute(context);
Ye handler ka core logic call hai
Kya hota hai:
TaskDefinition me jo handler assign hai, uska execute method call hota hai
SailPointContext pass hota hai → handler IAM system me kaam kar sakta hai
Result return hota hai → TaskResult


