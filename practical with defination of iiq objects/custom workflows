    </Script>
    <Transition to="Sample Form Step"/>
  </Step>

  <!-- STEP 3: DYNAMIC FORM STEP (Bina hierarchy crash kiye safe rendering) -->
  <Step icon="Approval" name="Sample Form Step" posX="300" posY="10">
    <Approval owner="ref:launcher" return="driveAction">
      <Arg name="workItemType" value="Form"/>
      
      <Form name="Sample Workflow Form">
