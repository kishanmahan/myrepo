Haan bhai, bilkul sahi pakde ho! IIQ (IdentityIQ) ke andar yeh kaam 100% Workflow ke ek BeanShell Script Step se hi hota hai.

Jab bhi koi employee company chhodta hai (Off-board/Leaver) ya delete hota hai, toh SailPoint ka standard engine automatic uske owned objects (jaise Application, Role, ya Workgroup) ka owner hatata nahi hai. Agar hum sahi waqt par unhe re-assign na karein, toh woh saare objects "Orphan" (bina owner ke) ho jaate hain, jo ki ek bada security audit issue hai.

Isliye BeanShell script ka use karke hum database se un saare objects ko khinchte hain, ek mast HTML table banate hain, aur direct email ke zariye notification bhej dete hain.

Aaiye iska ekdam complete live-project jaisa code aur workflow structure samajhte hain, jisme aapke bataye saare objects (Application, Bundle/Role, Workgroup, aur Rule) cover ho jayein:

Step 1: Poora Workflow Step Code (With BeanShell Script)
Is script mein humne SailPoint ke QueryOptions aur Filter API ka use kiya hai. Yeh direct database par Hibernate query chala kar bohot hi fast tarike se pata laga leta hai ki user kis-kis cheez ka owner hai:

XML
<Step icon="Task" name="Find All Owned Objects" posX="180" posY="10">
  <Script>
    <Source>
      <![CDATA[
      import sailpoint.object.Identity;
      import sailpoint.object.Bundle;
      import sailpoint.object.Application;
      import sailpoint.object.Rule;
      import sailpoint.object.QueryOptions;
      import sailpoint.object.Filter;
      import java.util.List;

      // 1. HTML Table ka sancha (Header) taiyar karo
      StringBuilder htmlTable = new StringBuilder();
      htmlTable.append("<table border='1' style='border-collapse: collapse; width: 100%; font-family: Arial, sans-serif;'>");
      htmlTable.append("<tr style='background-color: #0073e6; color: white;'>");
      htmlTable.append("<th style='padding: 8px;'>Object Name</th>");
      htmlTable.append("<th style='padding: 8px;'>Object Type</th>");
      htmlTable.append("</tr>");

      boolean hasObjects = false;

      if (identityName != null) {
          // Database se off-board hone waale user ka Identity object nikalo
          Identity ownerIdn = context.getObjectByName(Identity.class, identityName);
          
          if (ownerIdn != null) {
              
              // --- A. BUNDLES / ROLES CHECK ---
              QueryOptions qoRoles = new QueryOptions();
              qoRoles.addFilter(Filter.eq("owner", ownerIdn));
              List ownedRoles = context.getObjects(Bundle.class, qoRoles);
              if (ownedRoles != null && !ownedRoles.isEmpty()) {
                  hasObjects = true;
                  for (Bundle role : ownedRoles) {
                      htmlTable.append("<tr><td style='padding: 8px;'>").append(role.getName()).append("</td><td style='padding: 8px; color: #d9534f;'><b>Role / Access Profile</b></td></tr>");
                  }
              }

              // --- B. APPLICATIONS CHECK ---
              QueryOptions qoApps = new QueryOptions();
              qoApps.addFilter(Filter.eq("owner", ownerIdn));
              List ownedApps = context.getObjects(Application.class, qoApps);
              if (ownedApps != null && !ownedApps.isEmpty()) {
                  hasObjects = true;
                  for (Application app : ownedApps) {
                      htmlTable.append("<tr><td style='padding: 8px;'>").append(app.getName()).append("</td><td style='padding: 8px; color: #f0ad4e;'><b>Application</b></td></tr>");
                  }
              }

              // --- C. WORKGROUPS CHECK ---
              // IIQ me Workgroups bhi Identity table me hi hote hain (isWorkgroup = true)
              QueryOptions qoWorkgroups = new QueryOptions();
              qoWorkgroups.addFilter(Filter.eq("owner", ownerIdn));
              qoWorkgroups.addFilter(Filter.eq("isWorkgroup", true));
              List ownedWorkgroups = context.getObjects(Identity.class, qoWorkgroups);
              if (ownedWorkgroups != null && !ownedWorkgroups.isEmpty()) {
                  hasObjects = true;
                  for (Identity wg : ownedWorkgroups) {
                      htmlTable.append("<tr><td style='padding: 8px;'>").append(wg.getName()).append("</td><td style='padding: 8px; color: #5cb85c;'><b>Workgroup / Queue</b></td></tr>");
                  }
              }

              // --- D. RULES CHECK ---
              QueryOptions qoRules = new QueryOptions();
              qoRules.addFilter(Filter.eq("owner", ownerIdn));
              List ownedRules = context.getObjects(Rule.class, qoRules);
              if (ownedRules != null && !ownedRules.isEmpty()) {
                  hasObjects = true;
                  for (Rule rule : ownedRules) {
                      htmlTable.append("<tr><td style='padding: 8px;'>").append(rule.getName()).append("</td><td style='padding: 8px; color: #5bc0de;'><b>Business Rule</b></td></tr>");
                  }
              }
          }
      }

      htmlTable.append("</table>");

      // 2. Agar user kisi cheez ka owner mila, toh table workflow variable me save karo
      if (hasObjects) {
          workflow.put("ownedObjectsTable", htmlTable.toString());
          workflow.put("sendNotification", true);
      } else {
          workflow.put("sendNotification", false);
      }
      ]]>
    </Source>
  </Script>
  <!-- Agar owned items milein, toh Email step par jao, nahi toh direct khatam karo -->
  <Transition to="Send Reassignment Email" condition="script:(workflow.get(&quot;sendNotification&quot;) == true)"/>
  <Transition to="Stop"/>
</Step>
