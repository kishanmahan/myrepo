<Workflow explicitTransitions="true" name="Sample Workflow" type="IdentityLifecycle">

  <!-- Core Input Variables jo SailPoint system se automatic aayenge -->
  <Variable input="true" name="launcher">
    <Description>The user who clicked the QuickLink.</Description>
  </Variable>
