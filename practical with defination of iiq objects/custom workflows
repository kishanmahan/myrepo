<!DOCTYPE Rule PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<Rule name="Identity Offboarding Trigger Rule" type="IdentityTrigger">
  <Description>Yeh rule check karta hai ki user off-board ho raha hai ya nahi.</Description>
  <Source>
    <![CDATA[
    import sailpoint.object.Identity;

    boolean isOffboarding = false;

    if (newIdentity != null && oldIdentity != null) {
        String oldState = oldIdentity.getLifecycleState();
        String newState = newIdentity.getLifecycleState();
        
        // Agar state badla hai aur naya state 'inactive' ya 'terminated' ho gaya hai
        if (newState != null && !newState.equals(oldState)) {
            if ("inactive".equalsIgnoreCase(newState) || "terminated".equalsIgnoreCase(newState)) {
                isOffboarding = true;
            }
        }
    }

    return isOffboarding;
    ]]>
