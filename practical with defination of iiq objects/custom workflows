IdentityIQ mein is requirement ko bolte hain "Leaver / Off-boarding Notification for Object Owners".

IIQ ke andar agar koi Identity delete ya off-board ho rahi hai aur hume pata lagana hai ki woh kis-kis cheez (Application, Bundle/Role, Workgroup, ya Rule) ka Owner hai, aur un sabki table banakar email bhejni hai, toh yeh kaam Workflow ke andar ek BeanShell Script Step se hota hai.

Aaiye pure IIQ ke tareeqe se isko samajhte hain ki yeh kaise chalega:

IIQ Mein Iska Sahi Tarika Kya Hai?
IIQ mein hum ek Workflow Step banayenge jo target user ki ID lega, database par ek Hibernate criteria/query chalayega (jaise unke owned Roles aur Applications nikalne ke liye), aur un saari cheezon ko ek clean HTML Table () mein convert karke email body ke variable mein thonp dega.

Niche iska poora Workflow Step XML aur uski BeanShell Script di gayi hai:

XML
<Step icon="Task" name="Find Owned Objects and Build Table" posX="180" posY="10">
  <Script>
    <Source>
      <![CDATA[
      import sailpoint.object.Identity;
      import sailpoint.object.Bundle;
      import sailpoint.object.Application;
      import sailpoint.object.QueryOptions;
      import sailpoint.object.Filter;
      import java.util.List;

      // 1. StringBuilder se HTML table ka sancha (structure) taiyar karo
      StringBuilder htmlTable = new StringBuilder();
      htmlTable.append("<table border='1' style='border-collapse: collapse; width: 100%;'>");
      htmlTable.append("<tr style='background-color: #f2f2f2;'><th>Object Name</th><th>Object Type</th></tr>");

      boolean hasObjects = false;

      if (identityName != null) {
          Identity ownerIdn = context.getObjectByName(Identity.class, identityName);
          
          if (ownerIdn != null) {
              
              // --- A. ROLES (BUNDLES) OWNED CHECK ---
              QueryOptions qoRoles = new QueryOptions();
              qoRoles.addFilter(Filter.eq("owner", ownerIdn));
              List ownedRoles = context.getObjects(Bundle.class, qoRoles);
              
              if (ownedRoles != null && !ownedRoles.isEmpty()) {
                  hasObjects = true;
                  for (Bundle role : ownedRoles) {
                      htmlTable.append("<tr><td>").append(role.getName()).append("</td><td>Role / Access Profile</td></tr>");
                  }
              }

              // --- B. APPLICATIONS OWNED CHECK ---
              QueryOptions qoApps = new QueryOptions();
              qoApps.addFilter(Filter.eq("owner", ownerIdn));
              List ownedApps = context.getObjects(Application.class, qoApps);
              
              if (ownedApps != null && !ownedApps.isEmpty()) {
                  hasObjects = true;
                  for (Application app : ownedApps) {
                      htmlTable.append("<tr><td>").append(app.getName()).append("</td><td>Application</td></tr>");
                  }
              }
          }
      }

      htmlTable.append("</table>");

      // 2. Agar koi object mila, toh table ko workflow variable mein save karo, nahi toh khali message dalo
      if (hasObjects) {
          workflow.put("objectTableHtml", htmlTable.toString());
      } else {
          workflow.put("objectTableHtml", "<p>No owned objects found for this identity.</p>");
      }
      ]]>
    </Source>
  </Script>
  <Transition to="Send Offboarding Email"/>
</Step>
