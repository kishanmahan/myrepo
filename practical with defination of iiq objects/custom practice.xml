<!DOCTYPE Rule PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<Rule name="AD_Group" type="Custom">
<Source>
import sailpoint.object.Identity;
import sailpoint.object.Link;
import sailpoint.object.ProvisioningPlan;
import sailpoint.object.ProvisioningPlan.AccountRequest;
import sailpoint.object.ProvisioningPlan.AttributeRequest;
import sailpoint.object.ProvisioningProject;
import sailpoint.api.Provisioner; // Sahi API package
import org.apache.log4j.Logger;
import java.util.List;

Logger log = Logger.getLogger("sailpoint.Rules.AD_Group.rule");

if (identityName != null) {
    Identity idn = context.getObjectByName(Identity.class, identityName);
    
    if (idn != null) {
        // SailPoint ka standard boolean check user status ke liye
        boolean isInactive = idn.isInactive();

        if (!isInactive) {
            Link adLink = null;
            
            // Identity se unke saare links ki list nikaali
            List links = idn.getLinks();
            if (links != null) {
                for (Link lnk : links) {
                    // Sirf wahi link utha rahe hain jo AD application ka hai
                    if ("AD".equals(lnk.getApplicationName())) {
                        adLink = lnk;
                        break;
                    }
                }
            }

            // Check kar rahe hain ki kya user ke paas actual mein AD link mila ya nahi
            if (adLink != null) {
                ProvisioningPlan plan = new ProvisioningPlan();
                plan.setIdentity(idn);

                // Sahi variable 'adLink' se native identity (DN) fetch ki
                AccountRequest aqq = new AccountRequest(AccountRequest.Operation.Modify, "AD", null, adLink.getNativeIdentity());
                AttributeRequest att = new AttributeRequest("memberOf", ProvisioningPlan.Operation.Add, "Vpn_Group");
                
                aqq.add(att);
                plan.add(aqq);
                
                // Provisioner ka sahi package path use ho raha hai upar import ke throug
                Provisioner pro = new Provisioner(context);
                ProvisioningProject project = pro.compile(plan);
                pro.execute(project);
                
                log.info("Successfully group add ho gaya user ke liye: " + identityName);
            } else {
                log.error("User " + identityName + " ke paas AD Application ka account/link nahi mila.");
            }
        } else {
            log.error("User is InActive: " + identityName);
        }
    } else {
        log.error("Identity nahi mili database mein: " + identityName);
    }
}

return null;
</Source>
</Rule>
////////////*
identityName vs Link Name: context.getObjectByName() kisi object ko uske Unique Name se dhoondta hai.
Identity ka name uska username/employee ID hota hai (jaise john.doe), isliye Identity.class ke saath identityName pass karna ekdum sahi hai.
Lekin SailPoint ke database mein Link (Account) ka name identityName nahi hota! 
Link ka name aamtaur par target system ka unique identifier hota hai (jaise AD ka Distinguished Name: CN=John Doe,OU=Users,DC=domain,DC=com) ya fir ek random hex ID. 
