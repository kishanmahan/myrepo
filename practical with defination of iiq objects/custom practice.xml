<!DOCTYPE Rule PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<Rule name="resigner_remove_all_access_and_entitlements" type="Custom">
<Source>
import sailpoint.api.SailpointContext;
import sailpoint.api.Provisioner;
import org.apache.log4j.Logger;
import sailpoint.object.Identity;
import sailpoint.object.Filter;
import sailpoint.object.QueryOptions;
import sailpoint.object.ProvisioningPlan;
import sailpoint.object.ProvisioningPlan.AccountRequest;
import sailpoint.object.ProvisioningPlan.AttributeRequest;
import sailpoint.object.ProvisioningProject;
import sailpoint.object.Link;
import sailpoint.object.Entitlement;
import java.util.List;
import java.util.ArrayList;
import java.util.Calendar;
import java.util.Date;

Logger log = Logger.getLogger("sailpoint.Rules.resigner.removeAllAccess");

if (identityName != null) {
    Identity idn = context.getObjectByName(Identity.class, identityName);
    
    // 1. Check karo identity valid aur inactive hai ya nahi
    if (idn != null &amp;&amp; !idn.isActive()) {
        
        // 30 days pehle ki date nikaalo
        Calendar cal = Calendar.getInstance();
        cal.add(Calendar.DAY_OF_MONTH, -30);
        Date thirtyDaysAgo = cal.getTime();

        QueryOptions qo = new QueryOptions();
        qo.add(Filter.le("modified", thirtyDaysAgo));
        qo.add(Filter.eq("inactive", true)); 

        List idn2 = context.getObjects(Identity.class, qo);
        Identity idn2nd = null;

        if (idn2 != null) {
            for (Object idna : idn2) {
                Identity tempIdn = (Identity) idna;
                if (tempIdn.getName().equals(idn.getName())) {
                    idn2nd = tempIdn;
                    break;
                }
            }
        }

        // 2. Agar criteria match hua, toh access removal process start karo
        if (idn2nd != null) {
            ProvisioningPlan plan = new ProvisioningPlan();
            plan.setIdentity(idn2nd);
            
            boolean planHasOperations = false;

            // --- PART A: ROLES HATANE KE LIYE ---
            // User ke assigned ya detected roles ko remove karna
            List assignedRoles = idn2nd.getBundle(); // Assigned Roles
            if (assignedRoles != null &amp;&amp; !assignedRoles.isEmpty()) {
                for (Object roleObj : assignedRoles) {
                    sailpoint.object.Bundle role = (sailpoint.object.Bundle) roleObj;
                    if (role != null) {
                        log.info("Removing Role: " + role.getName() + " from user: " + identityName);
                        // IdentityRequest ke roop me role remove karne ka request
                        plan.add(AccountRequest.Operation.Modify, "IIQ", null, idn2nd.getName());
                        // IIQ application ke under role ko remove operation me daalna
                        AccountRequest iiqAccReq = plan.getAccountRequest("IIQ");
                        if(iiqAccReq != null) {
                            iiqAccReq.add(new AttributeRequest("assignedRoles", ProvisioningPlan.Operation.Remove, role.getName()));
                            planHasOperations = true;
                        }
                    }
                }
            }

            // --- PART B: APPLICATIONS AUR GROUPS HATANE KE LIYE ---
            List links = idn2nd.getLinks();
            if (links != null &amp;&amp; !links.isEmpty()) {
                
                // LOOP: Har ek application link par iterate karo
                for (Object l : links) {
                    Link linkk = (Link) l;
                    if (linkk != null) {
                        String appName = linkk.getApplicationName();
                        log.info("Processing Application for entitlement removal: " + appName);
                        
                        // Ek Modify Account Request banao taaki groups remove ho sakein
                        AccountRequest accReq = new AccountRequest(
                            AccountRequest.Operation.Modify, 
                            appName, 
                            null, 
                            linkk.getNativeIdentity()
                        );
                        
                        // Link ke andar jitne bhi Entitlements (Groups/Permissions) hain unhe dhoondo
                        List entitlements = linkk.getEntitlements();
                        if (entitlements != null &amp;&amp; !entitlements.isEmpty()) {
                            for (Object entObj : entitlements) {
                                Entitlement ent = (Entitlement) entObj;
                                if (ent != null) {
                                    String attrName = ent.getAttributeName(); // Jaise 'memberOf' ya 'groups'
                                    Object attrValue = ent.getValue();        // Group ka naam ya DN
                                    
                                    log.info("Removing Group/Entitlement: " + attrValue + " from attribute: " + attrName + " on App: " + appName);
                                    
                                    // AttributeRequest.Operation.Remove ka use karke group hatao
                                    accReq.add(new AttributeRequest(attrName, ProvisioningPlan.Operation.Remove, attrValue));
                                    planHasOperations = true;
                                }
                            }
                        }
                        
                        // OPTIONAL: Agar aap chahte hain ki groups hatne ke sath ACCOUNT BHI DISABLE ho jaye,
                        // toh aap ye niche wali line ka comment hata (uncomment) sakte hain:
                        // accReq.setOperation(AccountRequest.Operation.Disable);

                        plan.add(accReq);
                    }
                }
            }

            // 3. Compile aur Execute karo (Agar plan me kuch hatane ke liye mila)
            if (planHasOperations) {
                Provisioner pro = new Provisioner(context);
                ProvisioningProject project = pro.compile(plan);
                pro.execute(project);
                log.info("Saare Applications, Groups aur Roles successfully remove kar diye gaye hain for: " + identityName);
            } else {
                log.info("User ke paas pehle se hi koi active access/roles nahi the: " + identityName);
            }

        } else {
            log.warn("Identity " + identityName + " ne 30-day inactive criteria match nahi kiya.");
        }
    } else {
        log.error("Identity nahi mili ya active hai: " + identityName);
    }
}
return null;
</Source>
</Rule>

