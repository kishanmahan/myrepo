AttributeRequest att1=new AttributeRequest("memberOf",ProvisioningPlan.Operation.Add,"ADMIN_GROUP");
AttributeRequest att2=new AttributeRequest("memberOf",ProvisioningPlan.Operation.Add,"USER_GROUP");

entitlements=link.getEntitlements(context);
List<String> entitlevalue=new ArrayList<>();
for(Object entit:entitlements){
entitle=(Entitlement)entit;
if(entitle!=null &amp;&amp; "IT".equalsIgnoreCase(entitle.getAttributeValue())){

if(entitle.getAttributeValue()!=null){
if(!entitlevalue.contains(entitle.getAttributeValue())){
aqq.add(att1);
entitlevalue.add(entitle.getAttributeValue());
}}

}else if(entitle!=null &amp;&amp; "Finance".equalsIgnoreCase(entitle.getAttributeValue())){

if(entitle.getAttributeValue()!=null){
if(!entitlevalue.contains(entitle.getAttributeValue())){
aqq.add(att2);
entitlevalue.add(entitle.getAttributeValue());
}}

}else{
log.error("not found entitlement");
dobabaprovision=true;
}}


if(aqq.getAttributeRequests()!=null &amp;&amp; !aqq.getAttributeRequests().isEmpty()){
plan.add(aqq);
}else{
log.error("not found aqq");
return null;
}

if(plan.getAccountRequests()!=null &amp;&amp; !plan.getAccountRequests().isEmpty()){
project=pro.compile(plan);
pro.execute(project);
}else{
log.error("not found plan");
return null;
}

}else{log.error("AD link not found");return null;}

}else{
log.error("links not found he is new user");
return null;
}

}else{
log.error("idn not found");
return null;
}

}return null;
