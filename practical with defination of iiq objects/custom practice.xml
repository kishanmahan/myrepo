<!DOCTYPE Rule PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<Rule name="HR-Joiner-Automated-Provisioning-Rule" type="Validation">
  <Description>
    Yeh rule incoming identifier se HR user ko target karega aur bina approval ke direct Joiner provisioning execute karega.
  </Description>
  <Source>
    import sailpoint.object.Identity;
    import sailpoint.object.Link;
    import sailpoint.object.ProvisioningPlan;
    import sailpoint.object.ProvisioningPlan.AccountRequest;
    import sailpoint.object.ProvisioningPlan.AttributeRequest;
    import sailpoint.api.Provisioner;
    import sailpoint.tools.Util;
    import java.util.List;

    // --- CONFIGURATION ---
    // 1. Apna incoming identifier yahan pass karein (Yeh variable aapke process se aayega)
    String incomingUserIdentifier = "EMP10052"; 
    
    // 2. Apne HR Application ka exact naam yahan likhein
    String hrApplicationName = "HR-WORKDAY"; 
    
    // 3. Jo Role aap Joiner ko bina request ke dena chahte hain
    String joinerRoleName = "Joiner Base Access Role"; 
    // ---------------------

    if (Util.isNullOrEmpty(incomingUserIdentifier)) {
        return "Error: incomingUserIdentifier khaali (null) hai.";
    }

    // Identity find karna (Pehle exact Name se, fir unique object ID se)
    Identity identity = context.getObjectByName(Identity.class, incomingUserIdentifier);
    if (identity == null) {
        identity = context.getUniqueObject(Identity.class, incomingUserIdentifier);
    }

    if (identity == null) {
        return "Error: Identity '" + incomingUserIdentifier + "' SailPoint me nahi mili.";
    }

    // Check karna ki kya yeh user sach me HR source se aaya hai (Link check)
    boolean isHRUser = false;
    List links = identity.getLinks();
    if (links != null) {
        for (Link link : links) {
            if (link.getApplication() != null &amp;&amp; hrApplicationName.equals(link.getApplication().getName())) {
                isHRUser = true;
                break;
            }
        }
    }

    // Agar user HR source ka nahi hai toh process stop kar dena
    if (!isHRUser) {
        return "Skipped: Identity '" + identity.getName() + "' ke paas " + hrApplicationName + " ka link nahi hai. Yeh HR user nahi hai.";
    }

    // --- PROVISIONING PLAN BACKGROUND EXECUTION ---
    // Bina request portal (Access Request) ke direct assignment ke liye Plan banana
    ProvisioningPlan plan = new ProvisioningPlan();
    plan.setIdentity(identity);

    // IIQ application par Account Request banayein (Roles update karne ke liye)
    AccountRequest accReq = new AccountRequest(AccountRequest.Operation.Modify, "IIQ", null, identity.getName());
    
    // Identity par direct role assign karne ka attribute request
    AttributeRequest attReq = new AttributeRequest("assignedRoles", ProvisioningPlan.Operation.Add, joinerRoleName);
    accReq.add(attReq);
    plan.add(accReq);

    try {
        // Provisioner compile aur execute karega bina kisi workflow/manager approval ke
        Provisioner provisioner = new Provisioner(context);
        provisioner.compile(plan);
        provisioner.execute();
        
        return "Success: HR User '" + identity.getName() + "' ke liye Joiner access (" + joinerRoleName + ") successfully provision ho gaya.";
    } catch (Exception e) {
        return "Exception: Provisioning fail ho gayi: " + e.getMessage();
    }
  </Source>
</Rule>
