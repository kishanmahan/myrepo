Logger log=Logger.getLogger("sailpoint.Rules.createmodify_acc.rules");
if(identityName!=null){
Link linkk=null;
List links=null;
List&lt;Object&gt; linkks=new ArrayList&lt;Object&gt;();
Link lin=null;
Identity idn=context.getObjectByName(Identity.class,identityName);
if(idn!=null &amp;&amp; idn.isActive()){
links=idn.getLinks();
if(links!=null){
for(Object link:links){
linkk=(Link)link;
if("AD".equals(linkk.getApplicationName()) || "LDAP".equals(linkk.getApplicationName()))
linkks.add(linkk);
linkk=null;
}
for(int i=0;i&lt;linkks.size();i++){
lin=(Link)linkks.get(i);
if(lin!=null &amp;&amp; "AD".equals(lin.getApplicationName()))
{
ProvisioningPlan plan=new ProvisioningPlan();
Provisioner pro=new Provisioner(context);
ProvisioningProject project=null;
AccountRequest aqq=new AccountRequest(AccountRequest.Operation.Create,"AD",null,lin.getNativeIdentity());
AttributeRequest att=new AttributeRequest(ProvisioningPlan.Operation.Set,"memberOf","VPN_GROUP");
aqq.add(att);
plan.add(aqq);
project=pro.compile(plan);
pro.execute(project);

}else if(lin!=null &amp;&amp; "LDAP".equals(lin.getApplicationName())){
ProvisioningPlan plan=new ProvisioningPlan();
Provisioner pro=new Provisioner(context);
ProvisioningProject project=null;
AccountRequest aqq=new AccountRequest(AccountRequest.Operation.Modify,"LDAP",null,lin.getNativeIdentity());
AttributeRequest att=new AttributeRequest(ProvisioningPlan.Operation.Add,"Department","IT");
aqq.add(att);
plan.add(aqq);
project=pro.compile(plan);
pro.execute(project);
}
else{
log.error("AD and LDAP account not found");
return null;
}
}
}else{
log.error("links not found");
return null;
}
}else{
log.error("idn not found");
return null;
}
}
return null;
</Source>
</Rule>
