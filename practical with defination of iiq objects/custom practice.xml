<!DOCTYPE Rule PUBLIC "sailpoin.dtd" "sailpoint.dtd">
<Rule name="AD_Group" type="Custom">
<Source>
import sailpoint.object.Identity;
import org.apache.log4j.Logger;
import org.apache.log4j.Level;
import sailpoint.object.ProvisioningPlan;
import sailpoint.object.ProvisioningPlan.AccountRequest;
import sailpoint.object.ProvisioningPlan.AttributeRequest;
import sailpoint.api.Provisioner;
import sailpoint.object.ProvisioningProject;
import sailpoint.api.SailpointContextFactory;
import sailpoint.object.Link;
Logger log=Logger.getLogger("sailpoint.Rules.AD_Group.rule");
if(identityName!=null)
{
Link linkk=null;
Identity idn=context.getObjectByName(Identity.class,identityName);
if(idn!=null){
String status=(idn.getStatus()=="InActive")?"InActive":"Active";
List links=idn.getLinks();
for(Object link:links){
linkk=(Link)link;
if("AD".equals(linkk.getApplicationName()))
break;
}
if("Active".equals(status)&amp;&amp;linkk!=null)
{
ProvisioningPlan plan=new ProvisioningPlan();
AccountRequest aqq=new AccountRequest(AccountRequest.Operation.Modify,"AD",null,linkk.getNativeIdentity());
AttributeRequest att=new AttributeRequest(ProvisioningPlan.Operation.Add,"memberOf","Vpn_Group");
Provisioner pro=new Provisioner(context);
ProvisioningProject project=null;

aqq.add(att);
plan.add(aqq);
project=pro.compile(plan);
pro.execute(project);
log.info("completed executed");
}else{
log.error("user is InActive");
return null;
}

}else{
log.error("Identity not found");
return null;
}

}

return null;

</Source>
</Rule>
