<!DOCTYPE Rule PUBLIC "sailpoint.dtd" "sailpoint.dtd">
<Rule language="beanshell" name="Global-AfterProvisioning-Rule" type="AfterProvisioning">
  <Source>
  <![CDATA[
  import sailpoint.object.*;
  import sailpoint.api.ProvisioningPlan;
  import sailpoint.api.ProvisioningPlan.AccountRequest;
  import sailpoint.api.ProvisioningPlan.AttributeRequest;
  import org.apache.commons.logging.Log;
  import org.apache.commons.logging.LogFactory;

  Log customLogger = LogFactory.getLog("com.company.afterprovisioning");

  if (plan != null) {
      // 1. Result Check: Kya provisioning sach mein successful hui?
      ProvisioningResult result = plan.getResult();
      
      if (result != null && ProvisioningResult.STATUS_COMMITTED.equals(result.getStatus())) {
          
          List accReqs = plan.getAccountRequests();
          for (AccountRequest accReq : accReqs) {
              
              // 2. Sirf 'Create' operation ke baad welcome mail trigger karna
              if (AccountRequest.Operation.Create.equals(accReq.getOperation())) {
                  
                  String appName = accReq.getApplicationName();
                  String nativeIdentity = accReq.getNativeIdentity(); // AD ka DN ya ID
                  
                  customLogger.info("Success! Account created in " + appName + " with ID: " + nativeIdentity);

                  // 3. Post-Creation Logic: Triggering an Email
                  Identity user = plan.getIdentity();
                  if (user != null) {
                      String userEmail = user.getEmail();
                      if (userEmail != null) {
                          // Production mein yahan Email Template call hota hai
                          customLogger.info("Triggering Welcome Email to: " + userEmail);
                      }
                  }
              }
          }
      } else {
          customLogger.error("Provisioning failed or is still in 'Pending' state.");
      }
  }
  ]]>
  </Source>
</Rule>
