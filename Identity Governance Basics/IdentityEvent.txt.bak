import sailpoint.api.SailPointContext;
import sailpoint.api.SailPointContextFactory;
import sailpoint.object.Identity;
import sailpoint.object.IdentityEvent;
import sailpoint.tools.GeneralException;
import java.util.Date;
public class IdentityEventExample {

    public static void main(String[] args) {
        SailPointContext context = null;
        try {
            // 1️⃣ getContext() – Naya context create karo
            context = SailPointContextFactory.getContext();

            // 2️⃣ getIdentity() – Identity retrieve karo (Identity object)
            Identity user = context.getObjectByName(Identity.class, "ravi.kumar");

            // 3️⃣ Create IdentityEvent
            IdentityEvent event = new IdentityEvent();
            event.setId("EVT_1001");                  // setId()
            event.setIdentity(user);                  // setIdentity()
            event.setEventType("RoleAssigned");       // setEventType()
            event.setTarget("SAP Role");              // setTarget()
            event.setEventDate(new Date());           // setEventDate()
            event.setInitiator("Admin Amit");         // setInitiator()
            event.setStatus("Completed");             // setStatus()
            event.setComments("Quarterly role update");// setComments()
            event.setWorkflowTriggered(true);         // setWorkflowTriggered()

            // 4️⃣ save() – Context me persist karo
            context.saveObject(event);
            context.commitTransaction();

            // 5️⃣ getObjectById() – Event retrieve karo by ID
            IdentityEvent retrievedEvent = context.getObjectById(IdentityEvent.class, "EVT_1001");
            System.out.println("Retrieved Event: " + retrievedEvent.toString());

        } catch (GeneralException e) {
            e.printStackTrace();
        } finally {
            // 6️⃣ closeContext() – Resource release karo
            if (context != null) {
                SailPointContextFactory.closeContext(context);
            }
        }
    }
}
