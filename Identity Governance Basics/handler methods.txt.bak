🔹 2️⃣ Real Project Style Notepad-Friendly Code

Ye complete flow hai: Admin → TaskDefinition → Engine → Task → TaskResult → Executor + Handler

// File: DemoTaskExecutor.java
import java.util.HashMap;
import java.util.Map;

// Mock classes for Notepad simulation
class Task {
    private String name;
    public Task(String name){ this.name = name; }
    public String getName(){ return name; }
}

class TaskResult {
    enum Status { Ready, Running, Completed, Failure }
    private Status status;
    private Status completionStatus;
    private StringBuilder messages = new StringBuilder();

    public void setStatus(Status status){ this.status = status; }
    public void setCompletionStatus(Status completionStatus){ this.completionStatus = completionStatus; }
    public void addMessage(String msg){ messages.append(msg).append("\n"); }
    public Status getStatus(){ return status; }
    public Status getCompletionStatus(){ return completionStatus; }
    public String getMessages(){ return messages.toString(); }
}

class TaskContext {
    private Task task;
    private TaskResult result;
    public TaskContext(Task task, TaskResult result){ this.task = task; this.result = result; }
    public Task getTask(){ return task; }
    public TaskResult getTaskResult(){ return result; }
}

public class DemoTaskExecutor {

    private Map<String, Object> parameters = new HashMap<>();
    private Map<String, Object> results = new HashMap<>();

    // 1️⃣ Initialize task
    public void init(Task task){
        System.out.println("Initializing task: " + task.getName());
    }

    // 2️⃣ Set input parameters
    public void setParameters(Map<String, Object> params){
        this.parameters = params;
        System.out.println("Parameters set: " + params);
    }

    public Map<String,Object> getParameters(){ return parameters; }

    // 3️⃣ Core logic run
    public void execute(TaskContext context){
        Task task = context.getTask();
        TaskResult result = context.getTaskResult();

        System.out.println("Executing task: " + task.getName());
        result.setStatus(TaskResult.Status.Running);
        result.addMessage("Task started...");

        // ===== Core Logic =====
        // Example: Processing user provisioning
        String username = (String) parameters.get("username");
        if(username != null){
            result.addMessage("Processing user: " + username);
            // Simulate provisioning logic
            if(username.equals("jokerboy")){
                result.addMessage("Assigned role: Admin");
            } else {
                result.addMessage("Assigned role: User");
            }
        } else {
            result.addMessage("No user parameter found.");
        }

        // ===== End Core Logic =====
        result.setCompletionStatus(TaskResult.Status.Completed);
        result.addMessage("Task completed successfully.");

        // Save results
        results.put("Status", result.getCompletionStatus());
        results.put("Messages", result.getMessages());
    }

    // 4️⃣ Finish task
    public void finish(TaskResult result){
        result.addMessage("Finish method called.");
        System.out.println("Final TaskResult Status: " + result.getCompletionStatus());
    }

    // 5️⃣ Get results
    public Map<String,Object> getResults(){ return results; }

    // 6️⃣ Optional handler
    private void defaultHandler(Task task, TaskResult result){
        result.addMessage("Handler logic executed for task: " + task.getName());
    }

    // 7️⃣ Run full task simulation
    public static void main(String[] args){
        DemoTaskExecutor executor = new DemoTaskExecutor();

        // Admin creates TaskDefinition -> task name
        Task task = new Task("DemoProvisioningTask");
        TaskResult result = new TaskResult();
        TaskContext context = new TaskContext(task,result);

        executor.init(task);

        // Set parameters
        Map<String,Object> params = new HashMap<>();
        params.put("username","jokerboy");
        executor.setParameters(params);

        // Execute task (core logic)
        executor.execute(context);

        // Optional internal handler
        executor.defaultHandler(task,result);

        // Finish task
        executor.finish(result);

        // Print final results
        System.out.println("TaskResult Messages:\n" + result.getMessages());
        System.out.println("getResults() Map: " + executor.getResults());
    }
}
🔹 Sample Console Output
Initializing task: DemoProvisioningTask
Parameters set: {username=jokerboy}
Executing task: DemoProvisioningTask
TaskResult Messages:
Task started...
Processing user: jokerboy
Assigned role: Admin
Task completed successfully.
Handler logic executed for task: DemoProvisioningTask
Finish method called.

Final TaskResult Status: Completed
getResults() Map: {Status=Completed, Messages=Task started...
Processing user: jokerboy
Assigned role: Admin
Task completed successfully.
}
