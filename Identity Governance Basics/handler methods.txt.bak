🔹 1️⃣ public void review(AccessReview review):-
Purpose:-
Ye method single review object ko process karta hai
Developer yaha review ke rules ya actions define kar sakta hai.

🔹 2️⃣ public void performReviewActions():-
Purpose:-
Ye method sab reviews ke liye actions perform karta hai,
Example: Approve, Reject, Notify, Log messages.

🔹 3️⃣ public int getReviewCount():-
Purpose:-
Current reviews ka count return karta hai.

🔹 4️⃣ public void setReviewCount(int count):-
Purpose:-
Review count update karne ke liye
Developer ya engine use set kar sakta hai.
----------------------------------------------------------------
🔹 ✅ Notepad-Friendly Full Example
import java.util.ArrayList;
import java.util.List;

// Simulate AccessReview object
class AccessReview {
    private String username;
    private String role;
    private String status;

    public AccessReview(String username, String role){
        this.username = username;
        this.role = role;
        this.status = "NotReviewed";
    }

    public String getUsername(){ return username; }
    public String getRole(){ return role; }
    public String getStatus(){ return status; }
    public void setStatus(String status){ this.status = status; }
}

// ReviewExecutor simulates Access Review logic
public class ReviewExecutor {

    private int reviewCount = 0;

    public void review(AccessReview review){
        System.out.println("Reviewing access for user: " + review.getUsername());
        if("Admin".equals(review.getRole())){
            review.setStatus("Pending");
        } else {
            review.setStatus("Approved");
        }
    }

    public void performReviewActions(List<AccessReview> reviews){
        for(AccessReview r : reviews){
            review(r);
            System.out.println("Action performed for user: " + r.getUsername() 
                               + " Status: " + r.getStatus());
        }
        setReviewCount(reviews.size());
    }

    public int getReviewCount(){ return reviewCount; }
    public void setReviewCount(int count){
        this.reviewCount = count;
        System.out.println("Review count set to: " + count);
    }

    // Main simulation
    public static void main(String[] args){
        ReviewExecutor executor = new ReviewExecutor();

        List<AccessReview> reviews = new ArrayList<>();
        reviews.add(new AccessReview("jokerboy","User"));
        reviews.add(new AccessReview("alice","Admin"));

        executor.performReviewActions(reviews);

        System.out.println("Total reviews processed: " + executor.getReviewCount());
    }
}
🔹 Sample Output
Reviewing access for user: jokerboy
Action performed for user: jokerboy Status: Approved
Reviewing access for user: alice
Action performed for user: alice Status: Pending
Review count set to: 2
Total reviews processed: 2
