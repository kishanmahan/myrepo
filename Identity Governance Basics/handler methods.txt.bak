🔹 🔥 Full Notepad-Friendly Real Project Code
import java.util.*;

// ProvisioningPlan class
class ProvisioningPlan {
    private String username;
    private String action;
    private String value;

    public ProvisioningPlan(String username, String action, String value){
        this.username = username;
        this.action = action;
        this.value = value;
    }

    public String getUsername(){ return username; }
    public String getAction(){ return action; }
    public String getValue(){ return value; }

    public String toString(){
        return "Plan(" + username + ", " + action + ", " + value + ")";
    }
}

// ProvisioningResult class
class ProvisioningResult {
    private String username;
    private boolean success;

    public ProvisioningResult(String username, boolean success){
        this.username = username;
        this.success = success;
    }

    public String getUsername(){ return username; }
    public boolean isSuccess(){ return success; }
}

// Executor class
public class ProvisioningExecutor {

    // 1️⃣ Get Plans
    public List<ProvisioningPlan> getPlans(){
        List<ProvisioningPlan> plans = new ArrayList<>();

        plans.add(new ProvisioningPlan("jokerboy","ADD_ROLE","Admin"));
        plans.add(new ProvisioningPlan("alice","REMOVE_ROLE","User"));

        return plans;
    }

    // 2️⃣ Execute provisioning
    public ProvisioningResult provision(ProvisioningPlan plan){
        System.out.println("\nProvisioning for user: " + plan.getUsername());

        boolean success = true;

        if(plan.getAction().equals("ADD_ROLE")){
            System.out.println("Assigning role: " + plan.getValue());
        } else if(plan.getAction().equals("REMOVE_ROLE")){
            System.out.println("Removing role: " + plan.getValue());
        } else {
            success = false;
        }

        return new ProvisioningResult(plan.getUsername(), success);
    }

    // 3️⃣ Process result
    public void processResults(ProvisioningResult result){
        if(result.isSuccess()){
            System.out.println("SUCCESS: " + result.getUsername());
        } else {
            System.out.println("FAILED: " + result.getUsername());
        }
    }

    // Main flow
    public static void main(String[] args){
        ProvisioningExecutor executor = new ProvisioningExecutor();

        List<ProvisioningPlan> plans = executor.getPlans();

        for(ProvisioningPlan plan : plans){
            ProvisioningResult result = executor.provision(plan);
            executor.processResults(result);
        }
    }
}
🔹 🔥 Final Output
Provisioning for user: jokerboy
Assigning role: Admin
SUCCESS: jokerboy

Provisioning for user: alice
Removing role: User
SUCCESS: alice
