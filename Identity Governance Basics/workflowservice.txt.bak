🧠 ✅ Admin Level Code (SailPointFactory + Admin Context)
package com.example.admin;

import java.util.Map;
import java.util.List;
import java.util.Date;

import sailpoint.api.SailPointContext;
import sailpoint.api.SailPointFactory;
import sailpoint.object.Workflow;
import sailpoint.object.WorkflowCase;
import sailpoint.object.Task;
import sailpoint.object.QueryOptions;
import sailpoint.object.Filter;
import sailpoint.object.Identity;

public class AdminWorkflowUtil {

    // =========================
    // 🔹 GET ADMIN CONTEXT
    // =========================
    private SailPointContext getContext() throws Exception {
        return SailPointFactory.getCurrentContext();
    }

    // =========================
    // 🔥 RUN AS ADMIN (IMPORTANT)
    // =========================
    private void setAdminContext(SailPointContext context) throws Exception {

        Identity admin = context.getObjectByName(Identity.class, "spadmin");

        if (admin == null) {
            throw new RuntimeException("Admin not found");
        }

        context.setUser(admin); // 🔥 elevate privilege
    }

    // =========================
    // 🔹 LAUNCH WORKFLOW (ADMIN)
    // =========================
    public WorkflowCase launchWorkflowAsAdmin(String workflowName, Map<String, Object> args) throws Exception {

        SailPointContext context = getContext();
        setAdminContext(context); // 🔥 admin rights

        Workflow wf = context.getObjectByName(Workflow.class, workflowName);

        WorkflowCase wfCase = new WorkflowCase();
        wfCase.setWorkflow(wf);
        wfCase.setName(workflowName);
        wfCase.setVariables(args);
        wfCase.setStatus("Running");
        wfCase.setStart(new Date());

        context.saveObject(wfCase);
        context.commitTransaction();

        advance(wfCase);

        return wfCase;
    }

    // =========================
    // 🔹 FORCE RESUME (ADMIN)
    // =========================
    public void forceResume(String workflowCaseId) throws Exception {

        SailPointContext context = getContext();
        setAdminContext(context);

        WorkflowCase wfCase = context.getObjectById(WorkflowCase.class, workflowCaseId);

        wfCase.setStatus("Running"); // bypass checks

        context.saveObject(wfCase);
        context.commitTransaction();

        advance(wfCase);
    }

    // =========================
    // 🔹 FORCE TERMINATE
    // =========================
    public void forceTerminate(String workflowCaseId) throws Exception {

        SailPointContext context = getContext();
        setAdminContext(context);

        WorkflowCase wfCase = context.getObjectById(WorkflowCase.class, workflowCaseId);

        wfCase.setStatus("Terminated");

        context.saveObject(wfCase);
        context.commitTransaction();
    }

    // =========================
    // 🔹 CLEANUP WORKFLOWS
    // =========================
    public void deleteAllCompletedWorkflows() throws Exception {

        SailPointContext context = getContext();
        setAdminContext(context);

        QueryOptions qo = new QueryOptions();
        qo.addFilter(Filter.eq("status", "Completed"));

        List<WorkflowCase> list = context.getObjects(WorkflowCase.class, qo);

        for (WorkflowCase wfCase : list) {
            context.deleteObject(wfCase);
        }

        context.commitTransaction();
    }

    // =========================
    // 🔹 REASSIGN ALL TASKS
    // =========================
    public void reassignAllTasks(String oldUser, String newUser) throws Exception {

        SailPointContext context = getContext();
        setAdminContext(context);

        QueryOptions qo = new QueryOptions();
        qo.addFilter(Filter.eq("owner", oldUser));

        List<Task> tasks = context.getObjects(Task.class, qo);

        for (Task task : tasks) {
            task.setOwner(newUser);
            context.saveObject(task);
        }

        context.commitTransaction();
    }

    // =========================
    // 🔹 FORCE COMPLETE TASK
    // =========================
    public void forceCompleteTask(String taskId) throws Exception {

        SailPointContext context = getContext();
        setAdminContext(context);

        Task task = context.getObjectById(Task.class, taskId);

        task.setStatus("Completed");

        context.saveObject(task);

        WorkflowCase wfCase = task.getWorkflowCase();

        context.commitTransaction();

        advance(wfCase);
    }

    // =========================
    // 🔹 ADVANCE ENGINE
    // =========================
    private void advance(WorkflowCase wfCase) throws Exception {

        Object step = wfCase.getCurrentStep();

        while (step != null) {
            step = null; // simplified execution
            wfCase.setCurrentStep(step);
        }

        complete(wfCase);
    }

    // =========================
    // 🔹 COMPLETE
    // =========================
    private void complete(WorkflowCase wfCase) throws Exception {

        SailPointContext context = getContext();

        wfCase.setStatus("Completed");
        wfCase.setCurrentStep(null);

        context.saveObject(wfCase);
        context.commitTransaction();

        wfCase.getHistory().add("Admin completed at " + new Date());
    }
}
🔥 Admin Level Power (IMPORTANT)
Normal User:
   restricted operations ❌

Admin (spadmin):
   bypass validation ✔️
   force resume ✔️
   force terminate ✔️
   delete workflows ✔️
   reassign tasks ✔️
   
