()✅ 🔥 sailpoint.task.Handler kya hota hai?
👉 Ye ek interface / class concept hai jo task ke andar actual processing step ko define karta hai.

✅ 1️⃣ Admin (TaskDefinition Creation)
package com.example.sailpoint.admin;

import sailpoint.api.SailPointContext;
import sailpoint.object.TaskDefinition;

public class TaskDefinitionAdmin {

    public static TaskDefinition createTaskDefinition(SailPointContext context) throws Exception {

        TaskDefinition taskDef = new TaskDefinition();
        taskDef.setName("HandlerBasedTask");
        taskDef.setDescription("Task using real Handler architecture");
        taskDef.setExecutorClass("com.example.sailpoint.tasks.DeveloperTaskExecutor");
        taskDef.setCategory("Demo");
        taskDef.setTemplate(false);

        context.saveObject(taskDef);
        context.commitTransaction();

        System.out.println("TaskDefinition created: " + taskDef.getName());
        return taskDef;
    }
}
✅ 2️⃣ Handler Interface (Project Level – Clean Design)
package com.example.sailpoint.handler;

import sailpoint.api.SailPointContext;
import sailpoint.object.Task;
import sailpoint.task.TaskResult;

public interface TaskHandler {

    void execute(Task task, TaskResult result, SailPointContext context) throws Exception;
}
✅ 3️⃣ First Handler (Business Logic 1)
package com.example.sailpoint.handler;

import sailpoint.api.SailPointContext;
import sailpoint.object.Task;
import sailpoint.task.TaskResult;

public class ValidationHandler implements TaskHandler {

    @Override
    public void execute(Task task, TaskResult result, SailPointContext context) throws Exception {

        System.out.println("ValidationHandler started");

        if (task.getName() == null) {
            throw new Exception("Task name is null");
        }

        result.addMessage("Validation successful");
    }
}
✅ 4️⃣ Second Handler (Business Logic 2)
package com.example.sailpoint.handler;

import sailpoint.api.SailPointContext;
import sailpoint.object.Task;
import sailpoint.task.TaskResult;

public class ProcessingHandler implements TaskHandler {

    @Override
    public void execute(Task task, TaskResult result, SailPointContext context) throws Exception {

        System.out.println("ProcessingHandler running");

        for (int i = 1; i <= 3; i++) {
            result.addMessage("Processing step: " + i);
        }
    }
}
✅ 5️⃣ Third Handler (Finalization)
package com.example.sailpoint.handler;

import sailpoint.api.SailPointContext;
import sailpoint.object.Task;
import sailpoint.task.TaskResult;

public class CompletionHandler implements TaskHandler {

    @Override
    public void execute(Task task, TaskResult result, SailPointContext context) {

        System.out.println("CompletionHandler running");

        result.addMessage("Task completed successfully.");
    }
}
✅ 6️⃣ Executor (REAL COMPANY STYLE 🔥)
package com.example.sailpoint.tasks;

import sailpoint.api.SailPointContext;
import sailpoint.object.Task;
import sailpoint.task.TaskExecutor;
import sailpoint.task.TaskResult;

import java.util.ArrayList;
import java.util.List;

import com.example.sailpoint.handler.TaskHandler;
import com.example.sailpoint.handler.ValidationHandler;
import com.example.sailpoint.handler.ProcessingHandler;
import com.example.sailpoint.handler.CompletionHandler;

public class DeveloperTaskExecutor implements TaskExecutor {

    @Override
    public void execute(Task task, TaskResult result, SailPointContext context) {

        try {
            System.out.println("Executor started");

            result.setStatus(TaskResult.Status.Running);

            // 🔥 Handler Chain (Real pattern)
            List<TaskHandler> handlers = new ArrayList<TaskHandler>();
            handlers.add(new ValidationHandler());
            handlers.add(new ProcessingHandler());
            handlers.add(new CompletionHandler());

            // 🔥 Loop through handlers
            for (TaskHandler handler : handlers) {
                handler.execute(task, result, context);
            }

            result.setCompletionStatus(TaskResult.Status.Completed);

            System.out.println("Executor completed");

        } catch (Exception e) {
            result.setStatus(TaskResult.Status.Failure);
            result.addMessage("Error: " + e.getMessage());
            e.printStackTrace();
        }
    }
}
✅ 7️⃣ Engine Simulator
package com.example.sailpoint.engine;

import sailpoint.api.SailPointContext;
import sailpoint.object.Task;
import sailpoint.task.TaskResult;
import sailpoint.object.TaskDefinition;

public class TaskEngineSimulator {

    public static void runTask(SailPointContext context, TaskDefinition taskDef) {

        try {
            Task task = new Task();
            task.setName(taskDef.getName());
            task.setId("T1000");

            TaskResult result = new TaskResult();
            result.setStatus(TaskResult.Status.Ready);

            com.example.sailpoint.tasks.DeveloperTaskExecutor executor =
                    new com.example.sailpoint.tasks.DeveloperTaskExecutor();

            executor.execute(task, result, context);

            context.saveObject(result);
            context.commitTransaction();

            System.out.println("Final Status: " + result.getStatus());

        } catch (Exception e) {
            e.printStackTrace();
        }
    }
}
✅ 8️⃣ Main Class
package com.example.sailpoint.main;

import sailpoint.api.SailPointContext;
import sailpoint.api.SailPointFactory;

import com.example.sailpoint.admin.TaskDefinitionAdmin;
import com.example.sailpoint.engine.TaskEngineSimulator;
import sailpoint.object.TaskDefinition;

public class Main {

    public static void main(String[] args) throws Exception {

        SailPointContext context = null;

        try {
            context = SailPointFactory.createContext();

            TaskDefinition taskDef = TaskDefinitionAdmin.createTaskDefinition(context);

            TaskEngineSimulator.runTask(context, taskDef);

        } finally {
            if (context != null) {
                context.decache(true);
                context.close();
            }
        }
    }
}
