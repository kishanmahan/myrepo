import sailpoint.api.SailPointContext;
import sailpoint.api.SailPointFactory;
import sailpoint.object.IdentityRequest;
import sailpoint.object.ApprovalSet;

public class ApprovalExample {

    public static void main(String[] args) throws Exception {

        // 🔹 1️⃣ Get SailPoint Context (Entry Point)
        SailPointContext context = SailPointFactory.getCurrentContext();

        // 🔹 2️⃣ Fetch IdentityRequest from DB
        IdentityRequest req = context.getObjectByName(IdentityRequest.class, "REQ101");

        if (req != null) {

            // 🔹 3️⃣ Print Basic Info
            System.out.println("Request ID: " + req.getId());
            System.out.println("Requestor: " + req.getRequestor());
            System.out.println("Target User: " + req.getTargetIdentity());
            System.out.println("Current Status: " + req.getStatus());

            // 🔹 4️⃣ Requested Items (Kya maanga gaya)
            System.out.println("Requested Items: " + req.getRequestedItems());

            // 🔹 5️⃣ Approval Flow (Kaun approve karega)
            ApprovalSet approvalSet = req.getApprovalSet();
            System.out.println("Approval Flow: " + approvalSet);

            // ===========================
            // 🔥 APPROVE FLOW
            // ===========================
            req.setStatus("Approved");
            req.setCompleted(true);

            if (approvalSet != null) {
                approvalSet.setState("Approved");
                context.saveObject(approvalSet);
            }

            context.saveObject(req);
            context.commitTransaction();

            System.out.println("✅ Request Approved Successfully");

            // ===========================
            // 🔥 REJECT FLOW (Example)
            // ===========================
            req.setStatus("Rejected");
            req.setCompleted(true);

            if (approvalSet != null) {
                approvalSet.setState("Rejected");
                context.saveObject(approvalSet);
            }

            context.saveObject(req);
            context.commitTransaction();

            System.out.println("❌ Request Rejected Successfully");
        } else {
            System.out.println("⚠️ Request Not Found");
        }
    }
}
📤 🔥 Output Example
Request ID: REQ101
Requestor: Rahul
Target User: Amit
Current Status: Pending
Requested Items: [Admin Role, SAP Access]
Approval Flow: Manager -> Security

✅ Request Approved Successfully
❌ Request Rejected Successfully
----------------------------------------------------------------------------------------------
