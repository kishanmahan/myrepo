countLinks(Identity identity)
createLink(Identity identity, Application application)
saveLink(Link link)
deleteLink(Link link)
refreshLink(Link link)
getEntitlements(Link link)
setEntitlements(Link link, List entitlements)
addEntitlement(Link link, Entitlement entitlement)
removeEntitlement(Link link, Entitlement entitlement)
updateLink(Link link)
lockLink(Link link)
unlockLink(Link link)
cloneLink(Link link)
getDisabledLinks(Identity identity)
getActiveLinks(Identity identity)

mergeLinks(Link source, Link target)
searchLinks(QueryOptions options)
iterateLinks(QueryOptions options)
