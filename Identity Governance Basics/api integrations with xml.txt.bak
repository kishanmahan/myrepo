2️⃣ POST (Create User)
import java.net.URL;
import java.net.HttpURLConnection;
import java.io.OutputStream;

public class PostExample {

    public static void main(String[] args) {

        try {

            URL url = new URL("https://api.salesforce.com/users");

            HttpURLConnection conn =
                    (HttpURLConnection) url.openConnection();

            conn.setRequestMethod("POST");

            conn.setRequestProperty("Content-Type","application/json");

            conn.setDoOutput(true);

            String jsonInput =
                    "{\"username\":\"rahul\",\"email\":\"rahul@company.com\"}";

            OutputStream os = conn.getOutputStream();

            os.write(jsonInput.getBytes());

            os.flush();

            int responseCode = conn.getResponseCode();

            System.out.println("Response Code: " + responseCode);

        } catch(Exception e){

            System.out.println(e);

        }

    }

}
Output example
Response Code: 201

Matlab user create ho gaya.

3️⃣ PUT (Update User)
import java.net.URL;
import java.net.HttpURLConnection;
import java.io.OutputStream;

public class PutExample {

    public static void main(String[] args) {

        try {

            URL url = new URL("https://api.salesforce.com/users/101");

            HttpURLConnection conn =
                    (HttpURLConnection) url.openConnection();

            conn.setRequestMethod("PUT");

            conn.setRequestProperty("Content-Type","application/json");

            conn.setDoOutput(true);

            String jsonInput =
                    "{\"email\":\"rahul_new@company.com\"}";

            OutputStream os = conn.getOutputStream();

            os.write(jsonInput.getBytes());

            os.flush();

            int responseCode = conn.getResponseCode();

            System.out.println("Response Code: " + responseCode);

        } catch(Exception e){

            System.out.println(e);

        }

    }

}
Output example
Response Code: 200

Matlab user update ho gaya.

4️⃣ DELETE (Delete User)
import java.net.URL;
import java.net.HttpURLConnection;

public class DeleteExample {

    public static void main(String[] args) {

        try {

            URL url = new URL("https://api.salesforce.com/users/101");

            HttpURLConnection conn =
                    (HttpURLConnection) url.openConnection();

            conn.setRequestMethod("DELETE");

            int responseCode = conn.getResponseCode();

            System.out.println("Response Code: " + responseCode);

        } catch(Exception e){

            System.out.println(e);

        }

    }

}
Output example
Response Code: 204

Matlab user delete ho gaya.
